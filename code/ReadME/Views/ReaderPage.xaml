<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe_perso.Views.ReaderPage"
             Title="Liseuse">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Padding="15">

        <!-- Book Title and Page Indicator -->
        <VerticalStackLayout Grid.Row="0" Spacing="5">
            <Label 
                Text="{Binding CurrentBook.Title}"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#512BD4" />
            <Label 
                Text="{Binding PageIndicator}"
                FontSize="12"
                TextColor="#999999" />
        </VerticalStackLayout>

        <!-- Content Display -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10,20" Spacing="15">
                <Label 
                    Text="{Binding DisplayContent}"
                    FontSize="16"
                    LineHeight="1.6"
                    TextColor="#333333"
                    FontFamily="OpenSansRegular" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Navigation Controls -->
        <Grid 
            Grid.Row="2"
            ColumnDefinitions="*,*"
            ColumnSpacing="10"
            Padding="0,10">
            
            <Button 
                Grid.Column="0"
                Text="⬅️ Précédent"
                Command="{Binding PreviousPageCommand}"
                BackgroundColor="#FF6B9D"
                TextColor="White"
                CornerRadius="10"
                Padding="15" />

            <Button 
                Grid.Column="1"
                Text="Suivant ➡️"
                Command="{Binding NextPageCommand}"
                BackgroundColor="#4ECDC4"
                TextColor="White"
                CornerRadius="10"
                Padding="15" />

        </Grid>

    </Grid>

</ContentPage>
