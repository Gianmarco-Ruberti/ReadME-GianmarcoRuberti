<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe_perso.Views.TagManagementPage"
             Title="Gestion des Tags">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="15" Padding="15">

        <!-- Add New Tag Section -->
        <Frame 
            Grid.Row="0"
            CornerRadius="15"
            Padding="15"
            HasShadow="True"
            BackgroundColor="White">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                
                <!-- Tag Name Input -->
                <Entry 
                    Grid.Row="0"
                    Placeholder="Nom du nouveau tag"
                    Text="{Binding NewTagName}"
                    BackgroundColor="#F5F5F5" />

                <!-- Add Button -->
                <Button 
                    Grid.Row="1"
                    Text="➕ Ajouter Tag"
                    Command="{Binding AddTagCommand}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="15" />

            </Grid>
        </Frame>

        <!-- Info Text -->
        <Label 
            Grid.Row="1"
            Text="Tags existants"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="#512BD4"
            Margin="0,10,0,0" />

        <!-- Tags List -->
        <CollectionView 
            Grid.Row="2"
            ItemsSource="{Binding Tags}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame 
                        CornerRadius="12"
                        Padding="15"
                        HasShadow="True"
                        BackgroundColor="White">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            
                            <!-- Tag Info -->
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label 
                                    Text="{Binding Name}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{Binding Color}" />
                                <BoxView 
                                    WidthRequest="40"
                                    HeightRequest="20"
                                    CornerRadius="5"
                                    Color="{Binding Color}" />
                            </VerticalStackLayout>

                            <!-- Edit Button -->
                            <Button 
                                Grid.Column="1"
                                Text="✏️"
                                BackgroundColor="#FFB347"
                                TextColor="White"
                                CornerRadius="25"
                                WidthRequest="50"
                                HeightRequest="50"
                                Padding="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UpdateTagCommand}"
                                CommandParameter="{Binding .}" />

                            <!-- Delete Button -->
                            <Button 
                                Grid.Column="2"
                                Text="🗑️"
                                BackgroundColor="#FF6B6B"
                                TextColor="White"
                                CornerRadius="25"
                                WidthRequest="50"
                                HeightRequest="50"
                                Padding="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTagCommand}"
                                CommandParameter="{Binding .}" />

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
